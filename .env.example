# ===========================================
# AI 热点监控系统 · 环境变量示例
# 复制为 .env 并填写真实值
# ===========================================

# --- 数据库 ---
# 开发：SQLite 本地文件
DATABASE_URL="file:./dev.db"

# --- Auth.js ---
# 用 `openssl rand -base64 32` 或 https://generate-secret.vercel.app/32 生成
AUTH_SECRET="please-replace-with-random-32-chars"
# 应用部署地址（本地无需修改）
AUTH_URL="http://localhost:3000"

# GitHub OAuth（可选，留空则只支持邮箱密码登录）
# 申请：https://github.com/settings/applications/new
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- OpenRouter AI（系统级共享 Key）---
# 申请：https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# --- 抓取相关 ---
# 用于保护 /api/cron/ingest 端点
CRON_SECRET="please-replace-with-random-32-chars"

# Firecrawl 兜底（可选，反爬严格站才用得到）
# 申请：https://www.firecrawl.dev/
FIRECRAWL_API_KEY=""

# --- 第二阶段（X / Twitter，暂未启用）---
TWITTERAPI_IO_KEY=""
